{
  "name": "resume-parser-agent",
  "description": "Extracts structured info (name, contact, headline, skills, education, experience, summary) from raw resume text provided in the message. Read-only; returns JSON.",
  "instruction": { "$file": "instruction.md" },
  "toolsets": [],
  "visibility": "POD",
  "output_schema": {
    "type": "object",
    "properties": {
      "name": { "type": "string" },
      "email": { "type": "string" },
      "phone": { "type": "string" },
      "headline": { "type": "string" },
      "skills": { "type": "array", "items": { "type": "string" } },
      "education": { "type": "array", "items": { "type": "string" } },
      "experience": { "type": "array", "items": { "type": "string" } },
      "summary": { "type": "string" }
    },
    "required": ["skills", "summary"]
  },
  "permissions": { "grants": [] }
}
