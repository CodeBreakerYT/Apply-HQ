{
  "name": "interview-prep-agent",
  "description": "Researches and prepares interview notes (talking points, likely questions, company research) for one interview round. Read-only - a function persists the result.",
  "instruction": { "$file": "instruction.md" },
  "toolsets": ["POD", "WEB_SEARCH"],
  "visibility": "POD",
  "output_schema": {
    "type": "object",
    "properties": {
      "interview_id": { "type": "string" },
      "prep_notes": { "type": "string" },
      "likely_questions": { "type": "array", "items": { "type": "string" } }
    },
    "required": ["interview_id", "prep_notes", "likely_questions"]
  },
  "permissions": { "grants": [
    { "resource_type": "datastore_table", "resource_name": "applications",
      "permission_ids": ["datastore.table.read", "datastore.record.read"] },
    { "resource_type": "datastore_table", "resource_name": "interviews",
      "permission_ids": ["datastore.table.read", "datastore.record.read"] }
  ] }
}
