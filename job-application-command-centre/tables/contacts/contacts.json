{
  "name": "contacts",
  "primary_key_column": "id",
  "enable_rls": true,
  "visibility": "POD",
  "columns": [
    { "name": "name", "type": "TEXT", "required": true, "max_length": 200 },
    { "name": "email", "type": "TEXT", "max_length": 320 },
    { "name": "company", "type": "TEXT", "max_length": 200 },
    { "name": "title", "type": "TEXT", "max_length": 200 },
    { "name": "relationship", "type": "ENUM", "default": "recruiter",
      "options": ["recruiter", "referral", "hiring_manager", "alumni", "other"] },
    { "name": "linkedin_url", "type": "TEXT", "max_length": 500 },
    { "name": "last_contacted_at", "type": "DATE" },
    { "name": "notes", "type": "TEXT" }
  ],
  "config": {}
}
