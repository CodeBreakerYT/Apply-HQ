# Lemma pod connection (server-side secret - never expose to the frontend)
LEMMA_BASE_URL=https://api.lemma.work
LEMMA_ORG_ID=your-org-id
LEMMA_POD_ID=your-pod-id
# Access token (expires hourly). Auto-refreshed using the refresh token below.
LEMMA_TOKEN=your-lemma-access-token
# Refresh token (rotating). REQUIRED for a deployed backend. Get both from
# ~/.lemma/config.json after `lemma auth login`.
LEMMA_REFRESH_TOKEN=your-lemma-refresh-token

# Firebase project - used for Firestore access via REST (no service account).
FIREBASE_PROJECT_ID=jobapplicationcenter
FIREBASE_API_KEY=your-firebase-web-api-key

# Secret used to sign backend session JWTs. Generate a random one:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_JWT_SECRET=change-me-to-a-long-random-string

# Comma-separated allowed CORS origins (local dev + your Netlify site URL)
FRONTEND_ORIGIN=http://localhost:3000

# Optional: where to persist the rotating Lemma refresh token across restarts.
# On HuggingFace, enable persistent storage and use /data/lemma_session.json.
LEMMA_SESSION_FILE=/tmp/lemma_session.json
